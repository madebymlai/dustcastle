{
  "name": "dustcastle",
  "version": "0.4.5",
  "private": false,
  "description": "A global toolchain manager for AI coding agent sandboxes — one shared, deduplicated Nix store instead of per-project image builds.",
  "license": "MIT",
  "author": "Andrea Alai (madebymlai)",
  "homepage": "https://github.com/madebymlai/dustcastle#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/madebymlai/dustcastle.git"
  },
  "bugs": {
    "url": "https://github.com/madebymlai/dustcastle/issues"
  },
  "keywords": [
    "sandbox",
    "nix",
    "toolchain",
    "ai-agent",
    "coding-agent",
    "cli",
    "container",
    "reproducible"
  ],
  "type": "module",
  "bin": {
    "dustcastle": "dist/cli/main.js"
  },
  "files": [
    "dist",
    "!dist/**/*.test.js",
    "!dist/**/*.test.d.ts",
    "!dist/**/*.test.js.map"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && tsx scripts/copy-assets.ts",
    "dev": "tsx src/cli/main.ts",
    "test": "vitest run",
    "test:unit": "vitest run --project unit",
    "test:e2e": "vitest run --project e2e",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepack": "npm run build"
  },
  "dependencies": {
    "@ai-hero/sandcastle": "0.7.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.19.19",
    "tsx": "^4.19.2",
    "typescript": "^5.7.0",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=22"
  }
}
