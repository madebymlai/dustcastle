node_modules/
dist/
*.tsbuildinfo

# Nix build artifacts (nix-build -o result ...)
result
result-*

# dustcastle-owned rootless store lives under the user's home, never in-repo,
# but ignore any stray local copies / staging dirs.
.dustcastle/
/store-build/

# Throwaway spike (kept as reference until v1 supersedes it; never committed)
spike-go-store/

# Test scratch
/test/.tmp/

# Local agent harness config (per-machine, not project state)
.claude/

# sandcastle runtime output (logs + per-issue worktrees) — generated by a run,
# never project state. dustcastle's orchestration lives in src/, not a tracked
# .sandcastle config dir (unlike agentstack).
.sandcastle/

# Beads / Dolt files (added by bd init)
.dolt/
*.db
.beads-credential-key
.beads/proxieddb/
