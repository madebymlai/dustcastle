node_modules/
dist/
*.tsbuildinfo

# Nix build artifacts (nix-build -o result ...)
result
result-*

# dustcastle-owned rootless store lives under the user's home, never in-repo,
# but ignore any stray local copies / staging dirs.
.dustcastle/
/store-build/

# Test scratch
/test/.tmp/

# Local agent harness config (per-machine, not project state)
.claude/

# sandcastle runtime output (logs + per-issue worktrees) — generated by a run,
# never project state. dustcastle's orchestration lives in src/, not a tracked
# .sandcastle config dir (unlike agentstack).
.sandcastle/

# Beads / Dolt files (added by bd init)
.dolt/
*.db
.beads-credential-key
# beads runs purely local here: its dir (issue JSONL, Dolt DB, hooks, config) is
# git-excluded rather than git-synced. core.hooksPath is unset to match, so the
# beads commit hooks don't try to stage these now-ignored files.
/.beads/
# Local beads downgrade backup (clutter, never tracked).
/.beads.bak-pre-downgrade/

# Domain glossary kept local: untracked so an agent run can't re-commit an
# unreviewed version (see AGENTS.md "Domain docs"). Re-track deliberately if/when
# its contents are reviewed.
/CONTEXT.md
