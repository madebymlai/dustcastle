{
  "compilerOptions": {
    "target": "ES2023",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2023"],
    "types": ["node"],
    "outDir": "dist",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "exactOptionalPropertyTypes": true,
    "verbatimModuleSyntax": true,
    "declaration": true,
    "sourceMap": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true
  },
  // `scripts` (build tooling, run via tsx) is type-checked but never emitted — the
  // build config below re-adds rootDir:src and narrows include to ["src"] so only
  // runtime source ships into dist. `rootDir` lives there, not here, so type-checking
  // scripts/ outside src doesn't trip TS6059.
  "include": ["src", "scripts"],
  "exclude": ["node_modules", "dist", "spike-go-store"]
}
